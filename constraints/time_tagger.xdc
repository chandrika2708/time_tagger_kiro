#=============================================================================
# Section 9: DONT_TOUCH and Routing Constraints for Delay Lines
#=============================================================================
# Prevent optimization of the CARRY8 chain and ensure the tools do not
# reroute the carry chain connections.

set_property DONT_TOUCH TRUE [get_cells -hierarchical -filter {NAME =~ *gen_carry8*carry8_inst}]

# Prohibit routing optimization on carry chain nets
set_property IS_ROUTE_FIXED TRUE [get_nets -hierarchical -filter {NAME =~ *gen_carry8*carry_chain*}] -quiet

#=============================================================================
# Section 10: Timing Exceptions for Delay Line Sampling
#=============================================================================
# The CARRY8 delay line is an asynchronous path by nature (event_in propagates
# through combinational carry logic). The sampling flip-flops capture the
# thermometer code on the clock edge. This is intentionally metastable at the
# transition boundary - the bubble correction logic handles this.

# Set multicycle path for the pipeline register stage (bubble correction input)
set_multicycle_path 2 -setup \
    -from [get_cells -hierarchical -filter {NAME =~ *gen_carry8*}] \
    -to [get_cells -hierarchical -filter {NAME =~ *sample_reg*}]

set_multicycle_path 1 -hold \
    -from [get_cells -hierarchical -filter {NAME =~ *gen_carry8*}] \
    -to [get_cells -hierarchical -filter {NAME =~ *sample_reg*}]

#=============================================================================
# Section 11: Miscellaneous Constraints
#=============================================================================

# Target device
set_property PART xczu49dr-ffvf1760-2-e [current_project] -quiet

# Bitstream configuration
set_property BITSTREAM.GENERAL.COMPRESS TRUE [current_design] -quiet
set_property BITSTREAM.CONFIG.UNUSEDPIN PULLNONE [current_design] -quiet

# Configuration voltage
set_property CONFIG_VOLTAGE 1.8 [current_design] -quiet
set_property CFGBVS GND [current_design] -quiet

#=============================================================================
# End of constraints file
#=============================================================================
